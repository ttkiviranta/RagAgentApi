@using Markdig
@implements IAsyncDisposable

<div class="markdown-content prose prose-sm max-w-none dark:prose-invert">
    @if (!string.IsNullOrEmpty(renderedHtml))
    {
        @((MarkupString)renderedHtml)
    }
    else if (!string.IsNullOrWhiteSpace(MarkdownContent))
    {
        <p>Rendering...</p>
    }
</div>

<style>
    .markdown-content {
        color: inherit;
    }

    .markdown-content h1,
    .markdown-content h2,
    .markdown-content h3,
    .markdown-content h4,
    .markdown-content h5,
    .markdown-content h6 {
        font-weight: 700;
        margin-top: 1rem;
        margin-bottom: 0.5rem;
        line-height: 1.25;
    }

    .markdown-content h2 {
        font-size: 1.125rem;
    }

    .markdown-content h3 {
        font-size: 1rem;
    }

    .markdown-content p {
        margin-top: 0.5rem;
        margin-bottom: 0.5rem;
        line-height: 1.6;
    }

    .markdown-content ul,
    .markdown-content ol {
        margin-left: 1.5rem;
        margin-top: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .markdown-content li {
        margin-top: 0.25rem;
        margin-bottom: 0.25rem;
    }

    .markdown-content code {
        background-color: rgba(0, 0, 0, 0.1);
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
        font-family: monospace;
        font-size: 0.875rem;
    }

    .markdown-content pre {
        background-color: rgba(0, 0, 0, 0.05);
        padding: 0.75rem;
        border-radius: 0.5rem;
        overflow-x: auto;
        margin-top: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .markdown-content pre code {
        background-color: transparent;
        padding: 0;
        border-radius: 0;
    }

    .markdown-content blockquote {
        border-left: 4px solid currentColor;
        padding-left: 1rem;
        margin-left: 0;
        margin-top: 0.5rem;
        margin-bottom: 0.5rem;
        opacity: 0.9;
    }

    .markdown-content strong {
        font-weight: 700;
    }

    .markdown-content em {
        font-style: italic;
    }

    /* Dark mode */
    @@media (prefers-color-scheme: dark) {
        .markdown-content code {
            background-color: rgba(255, 255, 255, 0.1);
        }

        .markdown-content pre {
            background-color: rgba(0, 0, 0, 0.3);
        }
    }
</style>

@code {
    [Parameter]
    public string MarkdownContent { get; set; } = string.Empty;

    private string renderedHtml = string.Empty;

    protected override void OnParametersSet()
    {
        RenderMarkdown();
    }

    private void RenderMarkdown()
    {
        try
        {
            if (!string.IsNullOrWhiteSpace(MarkdownContent))
            {
                var pipeline = new MarkdownPipelineBuilder()
                    .UseAdvancedExtensions()
                    .Build();

                renderedHtml = Markdown.ToHtml(MarkdownContent, pipeline);
                Console.WriteLine($"[MarkdownRenderer] Rendered {MarkdownContent.Length} chars");
            }
            else
            {
                renderedHtml = string.Empty;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MarkdownRenderer] Error: {ex.Message}");
            renderedHtml = $"<p style='color:red;'>Error: {System.Web.HttpUtility.HtmlEncode(ex.Message)}</p>";
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        await Task.CompletedTask;
    }
}
