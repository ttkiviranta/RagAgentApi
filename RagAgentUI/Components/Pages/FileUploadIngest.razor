@page "/ingest-file"
@using RagAgentUI.Services
@using RagAgentUI.Models
@using System.IO
@using System.Text
@using iText.Kernel.Pdf
@using iText.Kernel.Pdf.Canvas.Parser
@inject RagApiClient ApiClient
@inject ILogger<FileUploadIngest> Logger

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-12 px-4">
    <div class="max-w-2xl mx-auto">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
                📄 Lataa PDF-dokumentti
            </h1>
            <p class="text-gray-600 dark:text-gray-400 mb-8">
                Lataa PDF-tiedosto integroitavaksi tietopohjaan. Järjestelmä käsittelee sen automaattisesti.
            </p>

            <div class="space-y-6">
                <!-- File Upload Input -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-4">
                        Valitse PDF-tiedosto
                    </label>
                    
                    <InputFile OnChange="OnFileSelected" accept=".pdf" 
                               class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 
                                      bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                    
                    @if (selectedFile != null)
                    {
                        <div class="mt-4 p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
                            <p class="text-sm font-medium text-blue-700 dark:text-blue-300">
                                ✓ Valittu: <span class="font-bold">@selectedFile.Name</span> (@FormatFileSize(selectedFile.Size))
                            </p>
                        </div>
                    }
                </div>

                <!-- Submit Button -->
                <button @onclick="IngestFile"
                        disabled="@(selectedFile == null || isProcessing)"
                        class="w-full px-6 py-3 bg-blue-500 hover:bg-blue-600 disabled:bg-gray-300 
                               text-white rounded-lg font-medium transition-colors text-lg
                               disabled:cursor-not-allowed">
                    @(isProcessing ? "Käsitellään PDF:ää..." : "🚀 Lataa PDF")
                </button>
            </div>

            <!-- Duplicate Document Modal -->
            @if (showDuplicateDialog)
            {
                <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl p-6 max-w-md">
                        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
                            ⚠️ Dokumentti on jo ladattu
                        </h2>
                        <p class="text-gray-600 dark:text-gray-400 mb-6">
                            Dokumentti nimellä "<strong>@selectedFile?.Name</strong>" on jo olemassa. 
                            Haluatko päivittää sen? Vanha versio poistetaan automaattisesti.
                        </p>
                        <div class="flex gap-3">
                            <button @onclick="() => { showDuplicateDialog = false; isProcessing = false; }"
                                    class="flex-1 px-4 py-2 bg-gray-300 hover:bg-gray-400 text-gray-900 rounded-lg font-medium">
                                Peruuta
                            </button>
                            <button @onclick="ProceedWithUpdate"
                                    class="flex-1 px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-lg font-medium">
                                Päivitä
                            </button>
                        </div>
                    </div>
                </div>
            }

            <!-- Progress -->
            @if (isProcessing)
            {
                <div class="mt-8 space-y-3">
                    <div class="flex items-center gap-3 p-4 rounded-lg bg-blue-50 dark:bg-blue-900/20">
                        <div class="w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
                        <span class="font-medium text-gray-700 dark:text-gray-300">
                            @progressMessage
                        </span>
                    </div>
                </div>
            }

            <!-- Success Message -->
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="mt-6 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
                    <div class="flex items-start gap-3">
                        <span class="text-green-500 text-2xl">✅</span>
                        <div>
                            <p class="font-medium text-green-700 dark:text-green-300">Onnistui!</p>
                            <p class="text-sm text-green-600 dark:text-green-400 mt-2 whitespace-pre-wrap">@successMessage</p>
                        </div>
                    </div>
                </div>
            }

            <!-- Error Message -->
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="mt-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg">
                    <div class="flex items-start gap-3">
                        <span class="text-red-500 text-2xl">❌</span>
                        <div>
                            <p class="font-medium text-red-700 dark:text-red-300">Virhe</p>
                            <p class="text-sm text-red-600 dark:text-red-400 mt-2 whitespace-pre-wrap">@errorMessage</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IBrowserFile selectedFile;
    private bool isProcessing = false;
    private bool showDuplicateDialog = false;
    private string progressMessage = "";
    private string successMessage = "";
    private string errorMessage = "";

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        errorMessage = "";
        
        if (selectedFile.Size > 50 * 1024 * 1024)
        {
            errorMessage = "Tiedosto on liian suuri. Maksimikoko on 50 MB.";
            selectedFile = null;
            return;
        }
        
        if (!selectedFile.ContentType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase))
        {
            errorMessage = "Valitse PDF-tiedosto.";
            selectedFile = null;
            return;
        }
    }

    private async Task IngestFile()
    {
        if (selectedFile == null)
        {
            errorMessage = "Valitse ensin PDF-tiedosto.";
            return;
        }

        isProcessing = true;
        progressMessage = "Tarkistetaan dokumenttia...";
        errorMessage = "";

        try
        {
            // Check if document already exists
            bool exists = await ApiClient.DocumentExistsAsync(selectedFile.Name);
            
            if (exists)
            {
                showDuplicateDialog = true;
                isProcessing = false;
                return;
            }
            
            await ProcessFileIngestion();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Virhe dokumentin tarkistuksessa");
            errorMessage = $"Virhe: {ex.Message}";
            isProcessing = false;
        }
    }

    private async Task ProceedWithUpdate()
    {
        showDuplicateDialog = false;
        isProcessing = true;
        progressMessage = "Poistetaan vanhaa dokumenttia...";

        try
        {
            bool deleteSuccess = await ApiClient.DeleteDocumentAsync(selectedFile.Name);
            progressMessage = "Ladataan uutta dokumenttia...";
            await ProcessFileIngestion();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Virhe dokumentin päivityksessä");
            errorMessage = $"Virhe: {ex.Message}";
            isProcessing = false;
            showDuplicateDialog = false;
        }
    }

    private async Task ProcessFileIngestion()
    {
        progressMessage = "Luetaan tiedostoa...";
        errorMessage = "";
        successMessage = "";

        try
        {
            var maxFileSize = 50 * 1024 * 1024;
            byte[] fileBytes;

            using (var stream = selectedFile.OpenReadStream(maxFileSize))
            using (var ms = new MemoryStream())
            {
                await stream.CopyToAsync(ms);
                fileBytes = ms.ToArray();
            }

            progressMessage = "Poistetaan tekstiä PDF:stä...";
            var pdfText = ExtractPdfText(fileBytes);
            
            if (string.IsNullOrWhiteSpace(pdfText))
            {
                pdfText = CreateDocumentContent(selectedFile.Name, fileBytes);
            }

            Logger.LogInformation("Ingesting PDF: {FileName}, Size: {Size}", selectedFile.Name, fileBytes.Length);
            progressMessage = "Käsitellään agentilla...";
            
            var response = await ApiClient.IngestTextAsync(pdfText, title: selectedFile.Name, source: "pdf-upload");

            if (response != null && response.ThreadId != Guid.Empty)
            {
                successMessage = $@"Dokumentti ladattu onnistuneesti! ✅

📄 Tiedostojen tiedot
━━━━━━━━━━━━━━━━━━━━
• Nimi: {selectedFile.Name}
• Koko: {FormatFileSize(fileBytes.Length)}
• Tila: ✅ Valmis

🚀 Seuraavat vaiheet
1. Siirry Chat-sivulle
2. Kysy kysymyksiä dokumentista";
            }
            else
            {
                errorMessage = "Dokumentin lataus epäonnistui.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Virhe tiedoston latauksen aikana");
            errorMessage = $"Virhe: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
            progressMessage = "";
        }
    }

    private string ExtractPdfText(byte[] fileBytes)
    {
        try
        {
            var extractedText = new StringBuilder();
            
            using (var reader = new PdfReader(new MemoryStream(fileBytes)))
            using (var doc = new PdfDocument(reader))
            {
                var pageCount = doc.GetNumberOfPages();
                
                for (int i = 1; i <= pageCount; i++)
                {
                    try
                    {
                        var page = doc.GetPage(i);
                        var text = PdfTextExtractor.GetTextFromPage(page);
                        
                        if (!string.IsNullOrWhiteSpace(text))
                        {
                            extractedText.AppendLine($"\n--- Sivu {i} ---\n");
                            extractedText.AppendLine(text);
                        }
                    }
                    catch { }
                }
            }
            
            return extractedText.ToString().Trim();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "PDF-tekstin poisto epäonnistui");
            return string.Empty;
        }
    }

    private string CreateDocumentContent(string fileName, byte[] fileBytes)
    {
        var fileSizeKb = fileBytes.Length / 1024.0;
        return $@"# Dokumentti: {fileName}

## Metatieto
- Nimi: {fileName}
- Koko: {fileSizeKb:F2} KB
- Latausaika: {DateTime.Now:yyyy-MM-dd HH:mm:ss}
- Tyyppi: PDF

Dokumentti ladattu Blazor-komponentin kautta.";
    }

    private string FormatFileSize(long bytes)
    {
        var units = new[] { "B", "KB", "MB", "GB" };
        var size = (double)bytes;
        var unitIndex = 0;

        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }

        return $"{size:F2} {units[unitIndex]}";
    }
}
