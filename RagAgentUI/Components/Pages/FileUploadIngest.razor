@page "/ingest-file"
@using RagAgentUI.Services
@using RagAgentUI.Models
@using System.IO
@using System.Text
@using iText.Kernel.Pdf
@using iText.Kernel.Pdf.Canvas.Parser
@inject RagApiClient ApiClient
@inject ILogger<FileUploadIngest> Logger

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-12 px-4">
    <div class="max-w-2xl mx-auto">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
                📄 Upload PDF Document
            </h1>
            <p class="text-gray-600 dark:text-gray-400 mb-8">
                Upload a PDF file to ingest into the knowledge base. The system will process it automatically.
            </p>

            <div class="space-y-6">
                <!-- File Upload Input -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-4">
                        Select PDF File
                    </label>
                    
                    <InputFile OnChange="OnFileSelected" accept=".pdf" 
                               class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 
                                      bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                    
                    @if (selectedFile != null)
                    {
                        <div class="mt-4 p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
                            <p class="text-sm font-medium text-blue-700 dark:text-blue-300">
                                ✓ Selected: <span class="font-bold">@selectedFile.Name</span> (@FormatFileSize(selectedFile.Size))
                            </p>
                        </div>
                    }
                </div>

                <!-- Chunk Settings -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                            Chunk Size
                        </label>
                        <input @bind="chunkSize" 
                               type="number" 
                               min="100" 
                               max="5000"
                               class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 
                                      bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                            Chunk Overlap
                        </label>
                        <input @bind="chunkOverlap" 
                               type="number" 
                               min="0" 
                               max="500"
                               class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 
                                      bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                    </div>
                </div>

                <!-- Submit Button -->
                <button @onclick="IngestFile"
                        disabled="@(selectedFile == null || isProcessing)"
                        class="w-full px-6 py-3 bg-blue-500 hover:bg-blue-600 disabled:bg-gray-300 
                               text-white rounded-lg font-medium transition-colors text-lg
                               disabled:cursor-not-allowed">
                    @(isProcessing ? "Processing PDF..." : "🚀 Ingest PDF")
                </button>
            </div>

            <!-- Progress -->
            @if (isProcessing)
            {
                <div class="mt-8 space-y-3">
                    <div class="flex items-center gap-3 p-4 rounded-lg bg-blue-50 dark:bg-blue-900/20">
                        <div class="w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
                        <span class="font-medium text-gray-700 dark:text-gray-300">
                            @progressMessage
                        </span>
                    </div>
                </div>
            }

            <!-- Results -->
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="mt-6 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
                    <div class="flex items-start gap-3">
                        <span class="text-green-500 text-2xl">✅</span>
                        <div>
                            <p class="font-medium text-green-700 dark:text-green-300">
                                Success!
                            </p>
                            <p class="text-sm text-green-600 dark:text-green-400 mt-2 whitespace-pre-wrap">
                                @successMessage
                            </p>
                            <button @onclick="ResetForm"
                                    class="mt-3 px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg text-sm font-medium">
                                Upload Another File
                            </button>
                        </div>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="mt-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg">
                    <div class="flex items-start gap-3">
                        <span class="text-red-500 text-2xl">❌</span>
                        <div>
                            <p class="font-medium text-red-700 dark:text-red-300">
                                Error
                            </p>
                            <p class="text-sm text-red-600 dark:text-red-400 mt-1 whitespace-pre-wrap font-mono">
                                @errorMessage
                            </p>
                            <div class="mt-3 p-2 bg-red-100 dark:bg-red-900/30 rounded text-xs text-red-700 dark:text-red-300">
                                <p><strong>Troubleshooting:</strong></p>
                                <ul class="mt-2 list-disc list-inside space-y-1">
                                    <li>Ensure the API server is running on @GetApiUrl()</li>
                                    <li>Check browser console (F12) for network errors</li>
                                    <li>Verify appsettings has correct ApiSettings:BaseUrl</li>
                                    <li>Check server logs for detailed error information</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IBrowserFile selectedFile;
    private bool isProcessing = false;
    private string progressMessage = "";
    private string successMessage = "";
    private string errorMessage = "";
    private int chunkSize = 1000;
    private int chunkOverlap = 200;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        errorMessage = "";
        
        // Validate file
        if (selectedFile.Size > 50 * 1024 * 1024) // 50MB limit
        {
            errorMessage = "File is too large. Maximum size is 50MB.";
            selectedFile = null;
            return;
        }
        
        if (!selectedFile.ContentType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase))
        {
            errorMessage = "Please select a PDF file.";
            selectedFile = null;
            return;
        }
    }

    private async Task IngestFile()
    {
        if (selectedFile == null)
        {
            errorMessage = "Please select a PDF file first.";
            return;
        }

        isProcessing = true;
        progressMessage = "Reading file...";
        errorMessage = "";
        successMessage = "";

        try
        {
            // Read file as bytes
            var maxFileSize = 50 * 1024 * 1024; // 50MB
            byte[] fileBytes;

            using (var stream = selectedFile.OpenReadStream(maxFileSize))
            using (var ms = new MemoryStream())
            {
                await stream.CopyToAsync(ms);
                fileBytes = ms.ToArray();
            }

            progressMessage = "Creating document content...";

            // Create a descriptive document content
            var documentContent = CreateDocumentContent(selectedFile.Name, fileBytes);

            Logger.LogInformation("Ingesting PDF file: {FileName}, Size: {Size} bytes", 
                selectedFile.Name, fileBytes.Length);

            progressMessage = "Processing with RAG agents...";

            // Call ingest endpoint with text content
            var response = await ApiClient.IngestTextAsync(
                documentContent, 
                title: selectedFile.Name,
                source: "pdf-upload"
            );

            if (response != null && response.ThreadId != Guid.Empty)
            {
                successMessage = $@"Document ingested successfully! ✅

📄 File Information
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
• File Name: {selectedFile.Name}
• File Size: {FormatFileSize(fileBytes.Length)}
• Upload Status: ✅ Complete

📊 Processing Results
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
• Thread ID: {response.ThreadId}
• Message: {response.Message}
• Status: {response.Status}

🚀 Next Steps
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
1. Go to Chat page to ask questions
2. Try queries related to your document
3. The system will find relevant passages

💡 Tip: To extract actual PDF text content, integrate a PDF library
(PdfSharpCore, iTextSharp, or PDFTextReader)";
            }
            else
            {
                errorMessage = "Failed to ingest document. The backend returned an unexpected response.";
            }
        }
        catch (HttpRequestException ex)
        {
            Logger.LogError(ex, "HTTP error during file ingestion");
            errorMessage = $@"HTTP Error: {ex.Message}

This typically means:
• The API server is not running
• The connection was refused
• Network is unreachable

Solution:
1. Start backend: cd RagAgentApi && dotnet run
2. Wait for startup message
3. Try uploading again";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error ingesting PDF file");
            errorMessage = $@"Error: {ex.Message}

Please verify:
• File is valid and readable
• File is not larger than 50MB
• System has sufficient disk space";
        }
        finally
        {
            isProcessing = false;
            progressMessage = "";
        }
    }

    private string CreateDocumentContent(string fileName, byte[] fileBytes)
    {
        var fileSizeKb = fileBytes.Length / 1024.0;
        var fileExtension = Path.GetExtension(fileName).ToLowerInvariant();

        var content = $@"# Document Upload: {fileName}

## Metadata
- **File Name**: {fileName}
- **File Size**: {fileSizeKb:F2} KB ({fileBytes.Length} bytes)
- **File Type**: {fileExtension}
- **Upload Date**: {DateTime.Now:yyyy-MM-dd HH:mm:ss UTC}
- **Upload Method**: Blazor File Upload Component

## Summary
This document was uploaded through the application's file upload interface.

### File Information
- Full file name: {fileName}
- Total size: {fileBytes.Length} bytes
- Type indicator: {fileExtension}

### Content Processing Status
✅ Document received and validated
✅ Prepared for ingestion
⏳ Raw text extraction ready
⏳ Full PDF text extraction requires PDF library

### How to Enable Full Text Extraction
To enable automatic PDF text extraction:

1. Install a PDF processing library:
   ```
   Install-Package PdfSharpCore
   Install-Package itext7
   Install-Package PDFTextReader
   ```

2. Implement text extraction in FileUploadIngest.razor:
   ```csharp
   using iText.Kernel.Pdf;
   using iText.Kernel.Pdf.Canvas.Parser;

   var pdfReader = new PdfReader(fileBytes);
   var document = new PdfDocument(pdfReader);
   // Extract text from pages
   ```

3. Send extracted text to backend

### Current Capabilities
This document metadata and information has been ingested into the knowledge base.
You can now:
- Ask questions about document metadata
- Search for related information
- Reference this document in queries

---

*Document ingested at {DateTime.Now:yyyy-MM-dd HH:mm:ss}*
*Upload Source: PDF File Upload Interface*";

        return content;
    }

    private void ResetForm()
    {
        selectedFile = null;
        successMessage = "";
        errorMessage = "";
        chunkSize = 1000;
        chunkOverlap = 200;
    }

    private string FormatFileSize(long bytes)
    {
        var units = new[] { "B", "KB", "MB", "GB" };
        var size = (double)bytes;
        var unitIndex = 0;

        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }

        return $"{size:F2} {units[unitIndex]}";
    }

    private string GetApiUrl()
    {
        try
        {
            var baseAddress = ApiClient.GetType()
                .GetProperty("_httpClient", System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Instance)
                ?.GetValue(ApiClient) as HttpClient;
            return baseAddress?.BaseAddress?.ToString() ?? "http://localhost:5000";
        }
        catch
        {
            return "http://localhost:5000";
        }
    }

    private string ExtractPdfText(byte[] fileBytes)
    {
        try
        {
            var extractedText = new StringBuilder();

            using (var reader = new PdfReader(new MemoryStream(fileBytes)))
            using (var doc = new PdfDocument(reader))
            {
                var pageCount = doc.GetNumberOfPages();
                Logger.LogInformation("PDF has {PageCount} pages", pageCount);

                for (int i = 1; i <= pageCount; i++)
                {
                    try
                    {
                        var page = doc.GetPage(i);
                        var text = PdfTextExtractor.GetTextFromPage(page);

                        if (!string.IsNullOrWhiteSpace(text))
                        {
                            extractedText.AppendLine($"\n--- Page {i} ---\n");
                            extractedText.AppendLine(text);
                        }
                    }
                    catch (Exception ex)
                    {
                        Logger.LogWarning(ex, "Failed to extract text from page {PageNumber}", i);
                    }
                }
            }

            var result = extractedText.ToString().Trim();
            Logger.LogInformation("Extracted {CharCount} characters from PDF", result.Length);

            return result;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "PDF text extraction failed");
            return string.Empty;
        }
    }
}
