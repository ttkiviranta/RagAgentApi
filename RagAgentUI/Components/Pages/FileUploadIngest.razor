@page "/ingest-file"
@using RagAgentUI.Services
@using RagAgentUI.Models
@using System.IO
@inject RagApiClient ApiClient
@inject ILogger<FileUploadIngest> Logger

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-12 px-4">
    <div class="max-w-2xl mx-auto">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
                📄 Upload PDF Document
            </h1>
            <p class="text-gray-600 dark:text-gray-400 mb-8">
                Upload a PDF file to ingest into the knowledge base. The system will process it automatically.
            </p>

            <div class="space-y-6">
                <!-- File Upload Input -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-4">
                        Select PDF File
                    </label>
                    
                    <InputFile OnChange="OnFileSelected" accept=".pdf" 
                               class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 
                                      bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                    
                    @if (selectedFile != null)
                    {
                        <div class="mt-4 p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg">
                            <p class="text-sm font-medium text-blue-700 dark:text-blue-300">
                                ✓ Selected: <span class="font-bold">@selectedFile.Name</span> (@FormatFileSize(selectedFile.Size))
                            </p>
                        </div>
                    }
                </div>

                <!-- Chunk Settings -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                            Chunk Size
                        </label>
                        <input @bind="chunkSize" 
                               type="number" 
                               min="100" 
                               max="5000"
                               class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 
                                      bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                            Chunk Overlap
                        </label>
                        <input @bind="chunkOverlap" 
                               type="number" 
                               min="0" 
                               max="500"
                               class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 
                                      bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                    </div>
                </div>

                <!-- Submit Button -->
                <button @onclick="IngestFile"
                        disabled="@(selectedFile == null || isProcessing)"
                        class="w-full px-6 py-3 bg-blue-500 hover:bg-blue-600 disabled:bg-gray-300 
                               text-white rounded-lg font-medium transition-colors text-lg
                               disabled:cursor-not-allowed">
                    @(isProcessing ? "Processing PDF..." : "🚀 Ingest PDF")
                </button>
            </div>

            <!-- Progress -->
            @if (isProcessing)
            {
                <div class="mt-8 space-y-3">
                    <div class="flex items-center gap-3 p-4 rounded-lg bg-blue-50 dark:bg-blue-900/20">
                        <div class="w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
                        <span class="font-medium text-gray-700 dark:text-gray-300">
                            @progressMessage
                        </span>
                    </div>
                </div>
            }

            <!-- Results -->
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="mt-6 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
                    <div class="flex items-start gap-3">
                        <span class="text-green-500 text-2xl">✅</span>
                        <div>
                            <p class="font-medium text-green-700 dark:text-green-300">
                                Success!
                            </p>
                            <p class="text-sm text-green-600 dark:text-green-400 mt-2 whitespace-pre-wrap">
                                @successMessage
                            </p>
                            <button @onclick="ResetForm"
                                    class="mt-3 px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg text-sm font-medium">
                                Upload Another File
                            </button>
                        </div>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="mt-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg">
                    <div class="flex items-start gap-3">
                        <span class="text-red-500 text-2xl">❌</span>
                        <div>
                            <p class="font-medium text-red-700 dark:text-red-300">
                                Error
                            </p>
                            <p class="text-sm text-red-600 dark:text-red-400 mt-1">
                                @errorMessage
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IBrowserFile selectedFile;
    private bool isProcessing = false;
    private string progressMessage = "";
    private string successMessage = "";
    private string errorMessage = "";
    private int chunkSize = 1000;
    private int chunkOverlap = 200;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        errorMessage = "";
        
        // Validate file
        if (selectedFile.Size > 50 * 1024 * 1024) // 50MB limit
        {
            errorMessage = "File is too large. Maximum size is 50MB.";
            selectedFile = null;
            return;
        }
        
        if (!selectedFile.ContentType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase))
        {
            errorMessage = "Please select a PDF file.";
            selectedFile = null;
            return;
        }
    }

    private async Task IngestFile()
    {
        if (selectedFile == null)
        {
            errorMessage = "Please select a PDF file first.";
            return;
        }

        isProcessing = true;
        progressMessage = "Reading file...";
        errorMessage = "";
        successMessage = "";

        try
        {
            // Read file to temporary location
            var tempPath = Path.Combine(Path.GetTempPath(), Guid.NewGuid() + "_" + selectedFile.Name);
            using (var stream = selectedFile.OpenReadStream(50 * 1024 * 1024))
            using (var fs = new FileStream(tempPath, FileMode.Create))
            {
                await stream.CopyToAsync(fs);
            }

            progressMessage = "Processing with RAG agents...";

            // Use file:// URL for ingestion
            var fileUrl = $"file:///{tempPath.Replace("\\", "/")}";
            
            Logger.LogInformation("Ingesting PDF file from: {FileUrl}", fileUrl);
            
            // Call ingest endpoint using existing method
            var response = await ApiClient.IngestUrlAsync(fileUrl);

            if (response != null && response.ThreadId != Guid.Empty)
            {
                successMessage = $@"Document ingested successfully!

📊 Results:
• Thread ID: {response.ThreadId}
• Message: {response.Message}
• Status: {response.Status}";

                // Clean up temp file
                try { File.Delete(tempPath); } catch { }
            }
            else
            {
                errorMessage = "Failed to ingest document. Please check the server logs.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error ingesting PDF file");
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
            progressMessage = "";
        }
    }

    private void ResetForm()
    {
        selectedFile = null;
        successMessage = "";
        errorMessage = "";
        chunkSize = 1000;
        chunkOverlap = 200;
    }

    private string FormatFileSize(long bytes)
    {
        var units = new[] { "B", "KB", "MB", "GB" };
        var size = (double)bytes;
        var unitIndex = 0;

        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }

        return $"{size:F2} {units[unitIndex]}";
    }
}
