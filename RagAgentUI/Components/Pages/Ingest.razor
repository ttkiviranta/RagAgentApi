@page "/ingest"
@using RagAgentUI.Services
@using RagAgentUI.Models
@inject RagApiClient ApiClient

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-12 px-4">
 <div class="max-w-2xl mx-auto">
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8">
 <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
      Add Document
     </h1>
           <p class="text-gray-600 dark:text-gray-400 mb-8">
       Ingest a URL into the knowledge base. The system will automatically detect the best agent.
   </p>

      <div class="space-y-6">
   <!-- URL Input -->
       <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
         Document URL
      </label>
        <input @bind="urlInput"
     @bind:event="oninput"
        type="url"
     placeholder="https://github.com/microsoft/semantic-kernel"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 
      bg-white dark:bg-gray-700 text-gray-900 dark:text-white
      focus:outline-none focus:ring-2 focus:ring-blue-500" />

     <div class="mt-2 text-sm text-gray-500">
         Supported: GitHub repos, YouTube videos, arXiv papers, news articles, web pages
       </div>
   </div>

   <!-- Advanced Options Toggle -->
   <div>
       <button @onclick="() => showAdvancedOptions = !showAdvancedOptions"
               type="button"
               class="flex items-center gap-2 text-sm text-blue-600 dark:text-blue-400 hover:underline">
           <span>@(showAdvancedOptions ? "▼" : "▶") Advanced Crawling Options</span>
       </button>
   </div>

   <!-- Crawl Options -->
   @if (showAdvancedOptions)
   {
       <div class="p-4 bg-gray-50 dark:bg-gray-700/50 rounded-lg space-y-4 border border-gray-200 dark:border-gray-600">
           <h3 class="font-medium text-gray-900 dark:text-white">Link Crawling</h3>

           <!-- Crawl Depth -->
           <div>
               <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                   Crawl Depth
                   <span class="ml-2 text-xs text-gray-500 font-normal">
                       (0 = only this page, 1 = follow links, 2 = two levels deep)
                   </span>
               </label>
               <select @bind="crawlDepth"
                       class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 
                              bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                   <option value="0">0 - Only this URL</option>
                   <option value="1">1 - Follow links on this page</option>
                   <option value="2">2 - Follow links two levels deep</option>
                   <option value="3">3 - Maximum depth (slow)</option>
               </select>
           </div>

           <!-- Max Pages -->
           @if (crawlDepth > 0)
           {
               <div>
                   <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                       Maximum Pages to Crawl
                   </label>
                   <input @bind="maxPages"
                          type="number"
                          min="1"
                          max="50"
                          class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 
                                 bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                   <p class="mt-1 text-xs text-gray-500">Limit: 1-50 pages (higher = slower)</p>
               </div>

               <!-- Same Domain Only -->
               <div class="flex items-center gap-3">
                   <input @bind="sameDomainOnly"
                          type="checkbox"
                          id="sameDomain"
                          class="w-4 h-4 text-blue-600 rounded border-gray-300" />
                   <label for="sameDomain" class="text-sm text-gray-700 dark:text-gray-300">
                       Stay on same domain only
                       <span class="text-xs text-gray-500 ml-1">(recommended)</span>
                   </label>
               </div>

               <!-- Warning -->
               <div class="p-3 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 rounded-lg">
                   <p class="text-sm text-yellow-800 dark:text-yellow-200">
                       ⚠️ Crawling multiple pages will take longer and use more resources. 
                       Estimated: ~@(maxPages * 3) seconds for @maxPages pages.
                   </p>
               </div>
           }
       </div>
   }

      <!-- Submit Button -->
      <button @onclick="IngestUrl"
       disabled="@(string.IsNullOrWhiteSpace(urlInput) || isIngesting)"
    class="w-full px-6 py-3 bg-blue-500 hover:bg-blue-600 disabled:bg-gray-300 
          text-white rounded-lg font-medium transition-colors text-lg
    disabled:cursor-not-allowed">
   @if (isIngesting)
   {
       <span>Processing @(crawlDepth > 0 ? $"(crawling up to {maxPages} pages)..." : "...")</span>
   }
   else
   {
       <span>@(crawlDepth > 0 ? $"Ingest URL + {maxPages} Linked Pages" : "Ingest Document")</span>
   }
     </button>
  </div>
       
   <!-- Progress/Status -->
      @if (ingestStatuses.Any())
  {
     <div class="mt-8 space-y-3">
   @foreach (var status in ingestStatuses)
      {
        <div class="flex items-center gap-3 p-4 rounded-lg @(status.IsComplete ? "bg-green-50 dark:bg-green-900/20" : "bg-blue-50 dark:bg-blue-900/20")">
      @if (status.IsComplete)
     {
        <span class="text-green-500 text-xl">✅</span>
       }
   else if (status.IsActive)
{
      <div class="w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
      }
       else
        {
   <span class="text-gray-400 text-xl">⏸️</span>
     }
        <span class="font-medium @(status.IsComplete ? "text-green-700 dark:text-green-300" : "text-gray-700 dark:text-gray-300")">
 @status.Label
  </span>
 </div>
   }
      </div>
      }

      <!-- Duplicate URL Confirmation Dialog -->
      @if (showUpdateConfirmation && existingDocument != null)
      {
          <div class="mt-6 p-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg">
              <div class="flex items-start gap-3">
                  <span class="text-yellow-500 text-2xl">⚠️</span>
                  <div class="flex-1">
                      <p class="font-medium text-yellow-700 dark:text-yellow-300">
                          This URL already exists in the database
                      </p>
                      <p class="text-sm text-yellow-600 dark:text-yellow-400 mt-1">
                          You have previously added this URL. Would you like to update the existing document?
                          This will delete the current version and re-ingest the content.
                      </p>
                      @if (existingDocument.LastUpdated.HasValue)
                      {
                          <p class="text-xs text-yellow-500 dark:text-yellow-500 mt-2">
                              Last updated: @existingDocument.LastUpdated.Value.ToString("g")
                          </p>
                      }
                      <div class="mt-4 flex gap-3">
                          <button @onclick="ConfirmUpdate"
                                  class="px-4 py-2 bg-yellow-600 hover:bg-yellow-700 text-white rounded-lg font-medium transition-colors">
                              Yes, Update Document
                          </button>
                          <button @onclick="CancelUpdate"
                                  class="px-4 py-2 bg-gray-500 hover:bg-gray-600 text-white rounded-lg font-medium transition-colors">
                              Cancel
                          </button>
                      </div>
                  </div>
              </div>
          </div>
      }

     @if (!string.IsNullOrEmpty(ingestResult))
    {
  <div class="mt-6 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
    <div class="flex items-start gap-3">
    <span class="text-green-500 text-2xl">🎉</span>
     <div>
       <p class="font-medium text-green-700 dark:text-green-300">
          Success!
   </p>
        <p class="text-sm text-green-600 dark:text-green-400 mt-1">
     @ingestResult
 </p>
   </div>
        </div>
   </div>
    }

     @if (!string.IsNullOrEmpty(errorMessage))
     {
      <div class="mt-6 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg">
    <div class="flex items-start gap-3">
    <span class="text-red-500 text-2xl">❌</span>
     <div>
     <p class="font-medium text-red-700 dark:text-red-300">
    Error
     </p>
      <p class="text-sm text-red-600 dark:text-red-400 mt-1">
 @errorMessage
  </p>
      </div>
     </div>
      </div>
     }
 </div>
   </div>
</div>

@code {
    private string urlInput = string.Empty;
    private bool isIngesting = false;
    private string? ingestResult = null;
    private string? errorMessage = null;

    // Crawl options
    private bool showAdvancedOptions = false;
    private int crawlDepth = 0;
    private int maxPages = 10;
    private bool sameDomainOnly = true;

    // Duplicate detection
    private bool showUpdateConfirmation = false;
    private Models.DocumentUrlCheckResult? existingDocument = null;

    private List<IngestStep> ingestStatuses = new();

    private async Task IngestUrl()
    {
        if (string.IsNullOrWhiteSpace(urlInput)) return;

        isIngesting = true;
        ingestResult = null;
        errorMessage = null;
        showUpdateConfirmation = false;
        existingDocument = null;

        try
        {
            // First, check if URL already exists
            var urlCheck = await ApiClient.CheckDocumentUrlExistsAsync(urlInput);

            if (urlCheck.Exists)
            {
                // URL already exists - ask user if they want to update
                existingDocument = urlCheck;
                showUpdateConfirmation = true;
                isIngesting = false;
                StateHasChanged();
                return;
            }

            // URL doesn't exist - proceed with ingestion
            await PerformIngestion();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            isIngesting = false;
        }

        StateHasChanged();
    }

    private async Task ConfirmUpdate()
    {
        showUpdateConfirmation = false;
        isIngesting = true;
        StateHasChanged();

        try
        {
            // Delete existing document first
            var deleteSuccess = await ApiClient.DeleteDocumentByUrlAsync(urlInput);

            if (!deleteSuccess)
            {
                errorMessage = "Failed to delete existing document. Please try again.";
                isIngesting = false;
                StateHasChanged();
                return;
            }

            // Now proceed with ingestion
            await PerformIngestion();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            isIngesting = false;
        }

        StateHasChanged();
    }

    private void CancelUpdate()
    {
        showUpdateConfirmation = false;
        existingDocument = null;
        StateHasChanged();
    }

    private async Task PerformIngestion()
    {
        ingestStatuses = new List<IngestStep>
        {
            new("Agent Selection", false, false),
            new("Scraping" + (crawlDepth > 0 ? $" ({maxPages} pages max)" : ""), false, false),
            new("Chunking", false, false),
            new("Embedding", false, false),
            new("Storing", false, false)
        };

        try
        {
            // Simulate progressive status (in real implementation, use SignalR for real-time updates)
            foreach (var step in ingestStatuses)
            {
                step.IsActive = true;
                StateHasChanged();
                await Task.Delay(crawlDepth > 0 ? 1000 : 500); // Longer delay for crawl
                step.IsActive = false;
                step.IsComplete = true;
                StateHasChanged();
            }

            var response = await ApiClient.IngestUrlAsync(urlInput, crawlDepth: crawlDepth, maxPages: maxPages, sameDomainOnly: sameDomainOnly);
            ingestResult = response.Message;
            urlInput = string.Empty;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            // Mark all remaining steps as incomplete
            foreach (var step in ingestStatuses.Where(s => s.IsActive))
            {
                step.IsActive = false;
            }
        }
        finally
        {
            isIngesting = false;
            StateHasChanged();
        }
    }

    private class IngestStep
    {
        public string Label { get; set; }
        public bool IsActive { get; set; }
        public bool IsComplete { get; set; }

        public IngestStep(string label, bool isActive, bool isComplete)
        {
            Label = label;
            IsActive = isActive;
            IsComplete = isComplete;
        }
    }
}