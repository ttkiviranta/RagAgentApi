@using Microsoft.AspNetCore.Components.Routing

<nav class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-6 py-3">
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-6">
            <NavLink href="/" 
                     title="AI-powered chat interface with RAG (Retrieval-Augmented Generation). Ask questions and get answers from your ingested documents."
                     class="text-gray-600 dark:text-gray-300 hover:text-blue-500 font-medium">
                💬 Chat
            </NavLink>
            <NavLink href="/ingest" 
                     title="Ingest web content by URL. Supports GitHub repos, YouTube videos, arXiv papers, news articles, and general web pages."
                     class="text-gray-600 dark:text-gray-300 hover:text-blue-500 font-medium">
                🌐 Ingest URL
            </NavLink>
            <NavLink href="/ingest-file" 
                     title="Upload and process PDF documents. Content is chunked, embedded, and stored for RAG queries."
                     class="text-gray-600 dark:text-gray-300 hover:text-blue-500 font-medium">
                📄 Upload PDF
            </NavLink>
            <NavLink href="/analytics" 
                     title="View system analytics: agent execution stats, document counts, query performance metrics."
                     class="text-gray-600 dark:text-gray-300 hover:text-blue-500 font-medium">
                📊 Analytics
            </NavLink>
            <NavLink href="/error-dashboard" 
                     title="Monitor application errors and exceptions. View error logs, severity levels, and stack traces."
                     class="text-gray-600 dark:text-gray-300 hover:text-red-500 font-medium">
