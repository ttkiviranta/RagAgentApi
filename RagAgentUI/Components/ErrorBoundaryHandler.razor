@using Microsoft.ApplicationInsights
@inject TelemetryClient TelemetryClient
@inject ILogger<ErrorBoundaryHandler> Logger

<CascadingValue Value="this">
    <ErrorBoundary @ref="errorBoundary">
        <ChildContent>
            @ChildContent
        </ChildContent>
        <ErrorContent Context="exception">
            <div class="error-container p-6 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg m-4">
                <div class="flex items-center gap-3 mb-4">
                    <span class="text-2xl">⚠️</span>
                    <h3 class="text-lg font-semibold text-red-700 dark:text-red-300">An error occurred</h3>
                </div>
                <p class="text-red-600 dark:text-red-400 mb-4">
                    @exception.Message
                </p>
                <button @onclick="Recover" 
                        class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors">
                    🔄 Try Again
                </button>
            </div>
        </ErrorContent>
    </ErrorBoundary>
</CascadingValue>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private ErrorBoundary? errorBoundary;

    protected override void OnInitialized()
    {
        // Subscribe to unhandled exceptions
        AppDomain.CurrentDomain.UnhandledException += OnUnhandledException;
    }

    private void OnUnhandledException(object sender, UnhandledExceptionEventArgs e)
    {
        if (e.ExceptionObject is Exception ex)
        {
            TrackException(ex, "UnhandledException");
        }
    }

    public void TrackException(Exception exception, string source = "UI")
    {
        // Log to Application Insights
        var properties = new Dictionary<string, string>
        {
            { "Source", $"BlazorUI-{source}" },
            { "Component", "RagAgentUI" },
            { "ExceptionType", exception.GetType().Name }
        };

        TelemetryClient.TrackException(exception, properties);
        TelemetryClient.Flush();

        // Also log locally
        Logger.LogError(exception, "[BlazorUI] Error in {Source}: {Message}", source, exception.Message);
    }

    public void TrackError(string message, string source = "UI")
    {
        var properties = new Dictionary<string, string>
        {
            { "Source", $"BlazorUI-{source}" },
            { "Component", "RagAgentUI" },
            { "Message", message }
        };

        TelemetryClient.TrackTrace(message, Microsoft.ApplicationInsights.DataContracts.SeverityLevel.Error, properties);
        Logger.LogError("[BlazorUI] Error in {Source}: {Message}", source, message);
    }

    private void Recover()
    {
        errorBoundary?.Recover();
    }

    public void Dispose()
    {
        AppDomain.CurrentDomain.UnhandledException -= OnUnhandledException;
    }
}
