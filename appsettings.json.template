{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "RagAgentApi.Agents": "Debug"
    },
    "ApplicationInsights": {
    "LogLevel": { 
    "Default": "Information" 
    }
    }
  },
  "AllowedHosts": "*",
  
  "ApplicationInsights": {
    "ConnectionString": "YOUR_APPLICATION_INSIGHTS_CONNECTION_STRING"
  },
  
  "Azure": {
    "OpenAI": {
      "Endpoint": "YOUR_AZURE_OPENAI_ENDPOINT",
      "Key": "YOUR_AZURE_OPENAI_KEY",
      "EmbeddingDeployment": "text-embedding-ada-002",
      "ChatDeployment": "gpt-35-turbo",
      "ApiVersion": "2024-02-15-preview",
  "MaxTokens": 8192,
      "Temperature": 0.7
    },
    "Search": {
      "Endpoint": "YOUR_AZURE_SEARCH_ENDPOINT",
      "Key": "YOUR_AZURE_SEARCH_KEY",
      "IndexName": "rag-agent-documents"
    },
    "Storage": {
      "ConnectionString": "YOUR_AZURE_STORAGE_CONNECTION_STRING",
   "ContainerName": "rag-documents"
    },
    "DocumentIntelligence": {
      "Endpoint": "YOUR_AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT",
      "Key": "YOUR_AZURE_DOCUMENT_INTELLIGENCE_KEY"
    }
  },

  "LlmProviders": {
    "Default": "AzureOpenAI",
    "OpenAICompatible": {
      "BaseUrl": "https://api.groq.com/openai/v1/chat/completions",
      "ApiKey": "YOUR_GROQ_API_KEY_OR_OTHER_PROVIDER",
      "ModelName": "qwen-2.5-7b",
      "MaxTokens": 8192,
      "Temperature": 0.7
    }
  },

  "RagSettings": {
    "Mode": "hybrid",
    "DefaultChunkSize": 1000,
    "DefaultChunkOverlap": 200,
    "MinChunkSize": 100,
    "MaxChunkSize": 5000,
    "DefaultTopK": 5,
    "MaxTopK": 50,
    "BatchSize": 100,
    "VectorDimensions": 1536,
    "MinimumSearchScore": 0.5
  },

  "Retrieval": {
    "Mode": "Rag",
    "AutoModeDocumentThreshold": 10,
    "AutoModeContentSizeThresholdKb": 500,
    "MinimumRelevanceScore": 0.5
  },

  "BlobStorage": {
    "Enabled": true,
    "ConnectionString": "YOUR_AZURE_BLOB_STORAGE_CONNECTION_STRING",
    "ContainerName": "rag-documents",
    "MaxFileSizeMb": 100
  },

  "NotificationConfigs":
        {
          "Channel": "email",
          "Enabled": false,
          "Recipients": ["operations@yourdomain.com"]
        },
        {
          "Channel": "teams",
          "Enabled": false,
          "WebhookUrl": "YOUR_TEAMS_WEBHOOK_URL"
        },
        {
          "Channel": "slack",
          "Enabled": false,
          "WebhookUrl": "YOUR_SLACK_WEBHOOK_URL"
        }
      ],

      "EmailSettings": {
        "Provider": "AzureCommunicationServices",
        "AzureCommunicationServicesConnectionString": "YOUR_AZURE_COMMUNICATION_SERVICES_CONNECTION_STRING",
        "SendGridApiKey": "YOUR_SENDGRID_API_KEY",
        "FromAddress": "alerts@yourdomain.com",
        "FromName": "RAG Agent Alerts"
      }
    }