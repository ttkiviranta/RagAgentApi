{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "System": "Information",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Warning",
      "RagAgentApi.Agents": "Trace"
    }
  },

  "ApplicationInsights": {
    "ConnectionString": "REPLACE_WITH_YOUR_APPLICATION_INSIGHTS_CONNECTION_STRING"
  },

  "Azure": {
    "OpenAI": {
      "Endpoint": "https://YOUR_RESOURCE_NAME.openai.azure.com/",
      "Key": "REPLACE_WITH_YOUR_AZURE_OPENAI_KEY",
      "EmbeddingDeployment": "text-embedding-ada-002",
      "ChatDeployment": "gpt-35-turbo",
      "ApiVersion": "2024-02-15-preview",
      "MaxTokens": 8192,
      "Temperature": 0.7
    },
    "Search": {
      "Endpoint": "https://YOUR_SEARCH_SERVICE.search.windows.net",
      "Key": "REPLACE_WITH_YOUR_AZURE_SEARCH_KEY",
      "IndexName": "rag-agent-documents"
    },
    "Storage": {
      "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=YOUR_STORAGE_ACCOUNT;AccountKey=REPLACE_WITH_YOUR_STORAGE_KEY;EndpointSuffix=core.windows.net",
      "ContainerName": "rag-documents"
    },
    "DocumentIntelligence": {
      "Endpoint": "https://YOUR_DOCUMENT_INTELLIGENCE_RESOURCE.cognitiveservices.azure.com/",
      "Key": "REPLACE_WITH_YOUR_DOCUMENT_INTELLIGENCE_KEY"
    }
  },

  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=ragagentdb;Username=postgres;Password=REPLACE_WITH_YOUR_POSTGRES_PASSWORD"
  },

  "RagSettings": {
    "Mode": "hybrid",
    "DefaultChunkSize": 1000,
    "DefaultChunkOverlap": 200,
    "MinChunkSize": 100,
    "MaxChunkSize": 5000,
    "DefaultTopK": 5,
    "MaxTopK": 50,
    "BatchSize": 100,
    "VectorDimensions": 1536,
    "MinimumSearchScore": 0.5
  },

  "DemoSettings": {
    "DataSource": "local",
    "LocalDataPath": "demos/",
    "PostgresConnectionString": "Host=localhost;Port=5432;Database=ragagentdb;Username=postgres;Password=REPLACE_WITH_YOUR_POSTGRES_PASSWORD",
    "SaveResults": true,
    "ResultRetentionDays": 30
  },

  "NotificationConfigs": [
    {
      "Id": "email-ops",
      "Channel": "email",
      "Enabled": false,
      "Recipients": ["operations@yourdomain.com"],
      "Description": "Send critical errors to operations email"
    },
    {
      "Id": "teams-dev",
      "Channel": "teams",
      "Enabled": false,
      "WebhookUrl": "REPLACE_WITH_YOUR_TEAMS_WEBHOOK_URL",
      "Description": "Send alerts to Teams development channel"
    },
    {
      "Id": "slack-alerts",
      "Channel": "slack",
      "Enabled": false,
      "WebhookUrl": "REPLACE_WITH_YOUR_SLACK_WEBHOOK_URL",
      "Description": "Send alerts to Slack channel"
    }
  ],

  "EmailSettings": {
    "Provider": "SendGrid",
    "SendGridApiKey": "REPLACE_WITH_YOUR_SENDGRID_API_KEY",
    "FromAddress": "alerts@yourdomain.com",
    "FromName": "RAG Agent Alerts"
  }
}